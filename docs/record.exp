#!/usr/bin/expect -f
# record.exp — Fully scripted expect session for the claude-code-free demo recording.
#
# Drives a complete install → SSH → Claude Code session automatically.
# Run via record.sh, not directly.
#
# Required env vars:
#   OPENROUTER_KEY   Your OpenRouter API key (sk-or-v1-...)
#
# Tuning constants:
#   CHAR_DELAY       ms between each typed character  (default 80 — ~12 chars/sec)
#   WORD_PAUSE       ms extra pause after each space  (default 100)
#   PROMPT_PAUSE     ms pause before responding to a prompt (viewer reads, then sees response)

set CHAR_DELAY   80
set WORD_PAUSE   100
set PROMPT_PAUSE 2000
set API_KEY      $env(OPENROUTER_KEY)
set timeout      300

# ---------------------------------------------------------------------------
# Helpers
# ---------------------------------------------------------------------------

proc type_slowly {text} {
    global CHAR_DELAY WORD_PAUSE
    foreach char [split $text ""] {
        send -- $char
        if {$char eq " "} {
            after $WORD_PAUSE
        } else {
            after $CHAR_DELAY
        }
    }
}

proc pause {ms} {
    after $ms
}

# ---------------------------------------------------------------------------
# Start shell — clean prompt, no banner, no clear
# Recording starts here: viewer sees a prompt and the curl command being typed
# ---------------------------------------------------------------------------
set env(TERM) xterm-256color
set env(PS1) {$ }
set env(PROMPT_EOL_MARK) {}

log_user 0
spawn zsh --no-rcs --no-globalrcs
expect "\$ "
log_user 1
pause 1500

# ---------------------------------------------------------------------------
# Type the curl install command — slowly so the viewer can read it
# ---------------------------------------------------------------------------
type_slowly "curl -fsSL https://raw.githubusercontent.com/JohnnyFoulds/claude-code-free/main/install.sh | bash"
pause 1000
send "\r"

# ---------------------------------------------------------------------------
# Welcome screen — let the viewer read it, then press Enter
# ---------------------------------------------------------------------------
expect "Press Enter to continue"
pause $PROMPT_PAUSE
send "\r"

# ---------------------------------------------------------------------------
# API key prompt — pause so viewer sees the prompt, then type
# ---------------------------------------------------------------------------
expect "Paste your OpenRouter API key"
pause $PROMPT_PAUSE
type_slowly $API_KEY
pause 800
send "\r"

# ---------------------------------------------------------------------------
# Model selection — pause, accept default
# ---------------------------------------------------------------------------
expect "Model ID"
pause $PROMPT_PAUSE
send "\r"

# ---------------------------------------------------------------------------
# Workspace selection — pause, choose 1
# ---------------------------------------------------------------------------
expect "Choose \[1/2/3\]"
pause $PROMPT_PAUSE
send "1\r"

# ---------------------------------------------------------------------------
# Container pull and start — wait for completion
# ---------------------------------------------------------------------------
expect -timeout 180 "Container started"
pause 1500

# ---------------------------------------------------------------------------
# "Try Claude Code right now?" — pause, say yes
# ---------------------------------------------------------------------------
expect "Try Claude Code right now"
pause $PROMPT_PAUSE
send "y\r"

# ---------------------------------------------------------------------------
# Wait for SSH connect and Claude Code header to appear
# ---------------------------------------------------------------------------
expect -timeout 60 "Claude Code"
pause 2500

# ---------------------------------------------------------------------------
# Type the demo prompt — slowly, with a long pause before so viewer reads
# the Claude Code UI first
# ---------------------------------------------------------------------------
type_slowly "write a python function that reads a csv file and returns the top 5 rows sorted by a given column"
pause 800
send "\r"

# ---------------------------------------------------------------------------
# Wait for Claude to finish — prompt returns as "❯ "
# ---------------------------------------------------------------------------
expect -timeout 120 -re "\n❯ $"
pause 3000

# ---------------------------------------------------------------------------
# Exit
# ---------------------------------------------------------------------------
type_slowly "exit"
send "\r"
expect -timeout 15 eof
