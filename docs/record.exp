#!/usr/bin/expect -f
# record.exp — Fully scripted expect session for the claude-code-free demo recording.
#
# Drives a complete install → SSH → Claude Code session automatically.
# Run via record.sh, not directly.
#
# Required env vars:
#   OPENROUTER_KEY   Your OpenRouter API key (sk-or-v1-...)
#
# Tuning constants:
#   CHAR_DELAY       ms between each typed character  (default 80 — ~12 chars/sec)
#   WORD_PAUSE       ms pause between words           (default 120)
#   PROMPT_PAUSE     ms pause before responding       (default 1200)

set CHAR_DELAY   80
set WORD_PAUSE   120
set PROMPT_PAUSE 1200
set API_KEY      $env(OPENROUTER_KEY)
set timeout      300

# ---------------------------------------------------------------------------
# Helpers
# ---------------------------------------------------------------------------

proc type_slowly {text} {
    global CHAR_DELAY WORD_PAUSE
    foreach char [split $text ""] {
        send -- $char
        if {$char eq " "} {
            after $WORD_PAUSE
        } else {
            after $CHAR_DELAY
        }
    }
}

proc pause {ms} {
    after $ms
}

# ---------------------------------------------------------------------------
# Start shell with clean prompt and TERM set
# ---------------------------------------------------------------------------
spawn env TERM=xterm-256color PS1="\$ " bash --norc --noprofile
expect "\$ "
pause 500
send "clear\r"
expect "\$ "
pause 800

# ---------------------------------------------------------------------------
# Type the curl install command
# ---------------------------------------------------------------------------
type_slowly "curl -fsSL https://raw.githubusercontent.com/JohnnyFoulds/claude-code-free/main/install.sh | bash"
pause 600
send "\r"

# ---------------------------------------------------------------------------
# Welcome screen
# ---------------------------------------------------------------------------
expect "Press Enter to continue"
pause $PROMPT_PAUSE
send "\r"

# ---------------------------------------------------------------------------
# Docker check (already running — no prompt expected, falls through)
# Step 2: API key
# ---------------------------------------------------------------------------
expect "Paste your OpenRouter API key"
pause $PROMPT_PAUSE

# Type the key — but redact it visually by sending it all at once
# (the recording will show the key being "typed" but at normal speed it looks fine)
# To fully redact: replace with a fake key in the recording
type_slowly "sk-or-v1-xxxx"
pause 200
# Send the rest silently then backspace the fake part and send real key
# Simpler: just type the real key slowly — the SVG shows it, so use a throwaway key
# OR set API_KEY to a visually plausible fake for the recording
send "\r"

# ---------------------------------------------------------------------------
# Model selection — accept default
# ---------------------------------------------------------------------------
expect "Model ID"
pause $PROMPT_PAUSE
send "\r"

# ---------------------------------------------------------------------------
# Workspace selection — choose 1
# ---------------------------------------------------------------------------
expect "Choose \[1/2/3\]"
pause $PROMPT_PAUSE
send "1\r"

# ---------------------------------------------------------------------------
# Container pull and start — wait for completion
# ---------------------------------------------------------------------------
expect -timeout 180 "Container started"
pause 1000

# ---------------------------------------------------------------------------
# "Try Claude Code right now?"
# ---------------------------------------------------------------------------
expect "Try Claude Code right now"
pause $PROMPT_PAUSE
send "y\r"

# ---------------------------------------------------------------------------
# Wait for SSH + Claude Code to load
# ---------------------------------------------------------------------------
expect -timeout 60 "Claude Code"
pause 2500

# ---------------------------------------------------------------------------
# Type the demo prompt slowly
# ---------------------------------------------------------------------------
type_slowly "write a python function that reads a csv file and returns the top 5 rows sorted by a given column"
pause 300
send "\r"

# ---------------------------------------------------------------------------
# Wait for Claude to finish responding
# The Claude Code prompt is a ">" character on its own line
# ---------------------------------------------------------------------------
expect -timeout 120 -re "\n❯ $"
pause 2500

# ---------------------------------------------------------------------------
# Exit
# ---------------------------------------------------------------------------
type_slowly "exit"
send "\r"
expect -timeout 15 eof
